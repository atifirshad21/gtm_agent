# ── Required ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...

# ── Optional: LangSmith tracing ───────────────────────
# Get a free API key at https://smith.langchain.com
# When enabled, every agent run is traced — node-by-node latency,
# token usage, LLM inputs/outputs, tool calls. Great for demos.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
# Project name is set in config.py (LANGSMITH_PROJECT), not here.
